    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.13.4",
    "@types/supertest": "^6.0.3",
    "mongodb-memory-server": "^10.3.0",
    "supertest": "^7.1.4",
