{
  "name": "disaster-management-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Industrial Disaster and Shift Coordination Platform - Monorepo",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "npm run dev --workspace=client",
    "dev:server": "npm run dev --workspace=server",
    "build": "npm run build --workspace=client && npm run build --workspace=server",
    "build:client": "npm run build --workspace=client",
    "build:server": "npm run build --workspace=server",
    "seed:server": "npm run seed --workspace=server",
    "test:server": "npm run test --workspace=server",
    "test:client": "npm run test --workspace=client"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
